<%@ page contentType="text/html;charset=UTF-8"%>
<%@ taglib uri="jakarta.tags.core" prefix="c"%>

	<p>

		<nav aria-label="breadcrumb" class="mb-3">
			<ol class="breadcrumb">
				<li class="breadcrumb-item"><a href="/">Início</a></li>
				<li class="breadcrumb-item">${entidade.modulo.titulo}</li>
				<li class="breadcrumb-item"><a href="/${entidade.classe.toLowerCase()}">${entidade.classe}</a></li>
				<li class="breadcrumb-item active" aria-current="page">Inclusão
					de ${entidade.titulo}s</li>
			</ol>
		</nav>
	<p>
	<div class="bd-example-snippet bd-code-snippet">
		<div class="bd-example m-0 border-0">

			<h3>${entidade.titulo}</h3>
			<hr />

			<form class="row needs-validation" name="${entidade.classe}form" method="POST"
				action="/${entidade.classe.toLowerCase()}" novalidate>

				<input type="hidden" name="id"> <input type="hidden"
					name="action" value="novo">
					
					#foreach( $campo in ${entidade.campos} )
						#parse("template/campos.vm")
					#end

				<p>
				<div class="col mb-3">
					<button type="submit" id="btnSalvar"
						class="btn btn-dark btn-sm py-1">
						<i class="bi-save"></i> Salvar
					</button>
					<a class="btn btn-secondary btn-sm py-1" formnovalidate
						href="/${entidade.classe.toLowerCase()}"><i class="bi-arrow-left"></i> Cancelar</a>
				</div>
			</form>
		</div>
	</div>

