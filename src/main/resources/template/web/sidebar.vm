<%@ page contentType="text/html;charset=UTF-8"%>

<div class="d-flex flex-column flex-shrink-0 p-3 text-white bg-dark"
	style="width: 280px; height: 710px;">
	<a href="/"
		class="d-flex align-items-center mb-3 mb-md-0 me-md-auto text-white text-decoration-none">
		<span class="fs-6 fw-bold">${projeto.titulo}</span>
	</a>
	<hr>
	<ul class="nav nav-pills flex-column mb-auto">
	
		#foreach($entidade in ${projeto.entidades} )
			#if(!$entidade.isMestre())
				<li><a href="/${entidade.classe.toLowerCase()}" class="nav-link text-white">${entidade.titulo}</a></li>
			#elseif($entidade.isMenuVisivel())
				<li><a href="/${entidade.classe.toLowerCase()}" class="nav-link text-white">${entidade.titulo}</a></li>
			#end
		#end
		
	</ul>
	<hr>
	<div class="dropdown">
		<a href="#"
			class="d-flex align-items-center text-white text-decoration-none dropdown-toggle"
			id="dropdownUser1" data-bs-toggle="dropdown" aria-expanded="false">
			<img src="https://github.com/mdo.png" alt="" width="32" height="32"
			class="rounded-circle me-2"> <strong>mdo</strong>
		</a>
		<ul class="dropdown-menu dropdown-menu-dark text-small shadow"
			aria-labelledby="dropdownUser1">
			<li><a class="dropdown-item" href="#">Preferencias</a></li>
			<li><hr class="dropdown-divider"></li>
			<li><a class="dropdown-item" href="#">Sair</a></li>
		</ul>
	</div>
</div>