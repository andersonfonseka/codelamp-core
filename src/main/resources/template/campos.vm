#if($campo.referencia)
	<div class="col-${campo.posicao} mb-3">
	<label for="nomeInput" class="form-label">${campo.rotulo}</label> 
	<select	name="${campo.getVarTipo()}Id" class="form-control" id="${campo.getVarTipo()}Input" required>
		<option value="">Selecione</option>
	
	<c:forEach var="c" items="*{${campo.nome.toLowerCase()}s}">
		<option value="*{c.id}" <c:if test="*{c.id eq ${campo.getVarTipo()}Id}">selected</c:if>>*{c.${campo.campoReferencia.toLowerCase()}}</option>
	</c:forEach>
	
	</select>
	<div class="invalid-feedback">Informe um valor válido para '${campo.nome}.'.</div>
	</div>
#elseif($campo.tipo == 'Enum')
	<div class="col-${campo.posicao} mb-3">
	<label for="nomeInput" class="form-label">${campo.rotulo}</label> 
	<select	name="${campo.getVarNome()}Id" class="form-control" id="${campo.getVarNome()}Input" required>
		<option value="">Selecione</option>
	
	<c:forEach var="c" items="*{Dominio${campo.nome}}">
		<option value="${c}">${c}</option>
	</c:forEach>
	
	</select>
	<div class="invalid-feedback">Informe um valor válido para '${campo.nome}.'.</div>
	</div>
#elseif($campo.tipo == 'Label')
	<div class="col-${campo.posicao} mb-3">
		<label for="${campo.getVarNome()}Input" class="form-label">${campo.rotulo}</label> 
		<input type="${campo.tipoEntrada}" name="${campo.getVarNome()}" class="form-control" required>
		<div class="invalid-feedback">Informe um valor válido para '${campo.nome}.'.</div>
	</div>
#elseif($campo.tipoView == 'textarea')
	<div class="col-${campo.posicao} mb-3">
		<label for="${campo.getVarNome()}Input" class="form-label">${campo.rotulo}</label> 
		<textarea name="${campo.getVarNome()}" class="form-control" cols="10" rows="3"></textarea>
		<div class="invalid-feedback">Informe um valor válido para '${campo.nome}.'.</div>
	</div>	
#elseif($campo.tipoView == 'img')
	<div class="col-${campo.posicao} mb-3">
		<label for="${campo.getVarNome()}Input" class="form-label">${campo.rotulo}</label> 
		<img src="" name="${campo.getVarNome()}" class="form-control"></img>
		<div class="invalid-feedback">Informe um valor válido para '${campo.nome}.'.</div>
	</div>	
#elseif($campo.tipo == 'double')
	<div class="col-${campo.posicao} mb-3">
		<label for="${campo.getVarNome()}Input" class="form-label">${campo.rotulo}</label> 
		<input type="${campo.tipoView}" step="any" name="${campo.getVarNome()}" class="form-control" required>
		<div class="invalid-feedback">Informe um valor válido para '${campo.nome}.'.</div>
	</div>
#else
	<div class="col-${campo.posicao} mb-3">
		<label for="${campo.getVarNome()}Input" class="form-label">${campo.rotulo}</label> 
		<input type="${campo.tipoEntrada}" name="${campo.getVarNome()}" class="form-control" required>
		<div class="invalid-feedback">Informe um valor válido para '${campo.nome}.'.</div>
	</div>
#end	